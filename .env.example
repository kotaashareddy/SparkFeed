# -----------------------------------------------------------------------------
# SparkFeed Environment Variables
# -----------------------------------------------------------------------------

# Database Configuration
# Local Dev: file:rss.db
# Cloud (Turso/Vercel): libsql://your-db-name.turso.io
DATABASE_URL=file:rss.db

# Turso Auth Token (Required for remote/cloud deployment)
# DATABASE_AUTH_TOKEN=your-token-here

# API Configuration
# Local Dev: http://localhost:3000
# Production: /api (detected automatically)
VITE_API_URL=/api
